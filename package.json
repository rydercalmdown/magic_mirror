{
  "name": "mmm-habittracker",
  "version": "1.0.0",
  "description": "A MagicMirror module for tracking daily habits with completion status",
  "main": "module.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "magicmirror",
    "module",
    "habits",
    "tracker",
    "productivity",
    "daily"
  ],
  "author": "Ryder Calmdown",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rydercalmdown/magic_mirror.git"
  },
  "bugs": {
    "url": "https://github.com/rydercalmdown/magic_mirror/issues"
  },
  "homepage": "https://github.com/rydercalmdown/magic_mirror#readme",
  "dependencies": {},
  "devDependencies": {},
  "engines": {
    "node": ">=14.0.0"
  },
  "magicmirror": {
    "module": "MMM-HabitTracker",
    "position": "top_right",
    "config": {
      "updateInterval": 60000,
      "habits": [
        "Brush teeth",
        "Floss", 
        "Exercise",
        "Read for 30 minutes",
        "Meditate"
      ],
      "backendUrl": "http://localhost:5000",
      "showCompletedCount": true,
      "showProgressBar": true
    }
  }
}
