{
  "name": "mmm-habittracker",
  "version": "1.0.0",
  "description": "A MagicMirror module for tracking daily habits with completion status",
  "main": "module.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "pm2 start ecosystem.config.js",
    "stop": "pm2 stop magic-mirror-backend",
    "restart": "pm2 restart magic-mirror-backend",
    "reload": "pm2 reload magic-mirror-backend",
    "delete": "pm2 delete magic-mirror-backend",
    "logs": "pm2 logs magic-mirror-backend",
    "status": "pm2 status magic-mirror-backend",
    "monit": "pm2 monit"
  },
  "keywords": [
    "magicmirror",
    "module",
    "habits",
    "tracker",
    "productivity",
    "daily"
  ],
  "author": "Ryder Calm Down",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rydercalmdown/magic_mirror.git"
  },
  "bugs": {
    "url": "https://github.com/rydercalmdown/magic_mirror/issues"
  },
  "homepage": "https://github.com/rydercalmdown/magic_mirror#readme",
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^5.1.0"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "magicmirror": {
    "module": "MMM-HabitTracker",
    "position": "top_right",
    "config": {
      "updateInterval": 60000,
      "habits": [
        "Brush teeth",
        "Floss",
        "Exercise",
        "Read for 30 minutes",
        "Meditate"
      ],
      "backendUrl": "http://localhost:5000",
      "showCompletedCount": true,
      "showProgressBar": true
    }
  }
}
